# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# app data (local catalog json)
/data

# secrets: YouTube cookies / GCP service-account key
cookies.txt
*-key.json
sa-key.json

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (secrets) — but keep the example template
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
