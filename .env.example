# Copy this file to .env.local and fill in your values.

# ---- Cloudinary — free account at https://cloudinary.com/users/register_free ----
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- MongoDB ----
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://USER:PASS@cluster.xxxx.mongodb.net
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=sonix

# ---- Vertex AI (Gemini) ----
# Turn the whole AI recommendations feature on/off. Set to false on hosts
# without Vertex credentials — the app runs fine, just hides recommendations.
AI_ENABLED=true
GCP_PROJECT=your_gcp_project
GCP_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash-lite
# Local dev uses your gcloud ADC automatically.
# On a server, set this to a service-account JSON key file:
# GOOGLE_APPLICATION_CREDENTIALS=/home/ubuntu/sonix/sa-key.json

# ---- yt-dlp tooling ----
# Windows: PYTHON_PATH=python   |   Linux/EC2: PYTHON_PATH=python3
PYTHON_PATH=python
# Folder containing ffmpeg (Windows). Leave blank if ffmpeg is on PATH (Linux).
FFMPEG_LOCATION=

# ---- Cloud download reliability (EC2 etc.) ----
# YouTube blocks datacenter IPs. Provide a cookies file (exported from a
# logged-in browser) and/or a residential proxy to get past bot checks.
# Leave blank on local/residential machines.
YTDLP_COOKIES=
YTDLP_PROXY=
