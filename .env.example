# Copy this file to .env.local and fill in your values.

# Cloudinary — free account at https://cloudinary.com/users/register_free
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Folder containing ffmpeg.exe (Windows). Leave blank if ffmpeg is on PATH.
FFMPEG_LOCATION=

# Python executable to run yt-dlp via `python -m yt_dlp`.
PYTHON_PATH=python
